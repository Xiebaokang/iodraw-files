        <mxCell id="WgSi36YBb3g61TZYZooB-184" value="&lt;b&gt;wid&lt;/b&gt;为block中的warp序号&amp;nbsp; &amp;nbsp;=&amp;gt;&amp;nbsp; &lt;b&gt;wid = tid / warpsize;&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
