        <mxCell id="WgSi36YBb3g61TZYZooB-146" value="block的序号都以pid表示，也就是blockidx只有一个维度，所以有" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="28" y="832" width="350" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-147" value="&lt;b&gt;注：&lt;/b&gt;上一节中的pid = pid % (pid /&amp;nbsp;LocalSplitU)，所以pid_m/n都已被确认" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="28" y="859.5" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-149" value="&lt;b&gt;pid_x = pid_n&lt;br&gt;pid_y = pid_m&lt;br&gt;pid_z = pid / (pid % LocalSplitU)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="38" y="892" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-150" value="在ShA/B中取数据时，需要修改成：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="28" y="952" width="210" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-151" value="&lt;b&gt;等距&lt;/b&gt;：ShA[iter_k][xxxx]&amp;nbsp; =&amp;gt;&amp;nbsp; ShA[pid_z * block_size_k / LocalSplitU + iter_k][xxxx]" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="28" y="1012" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-152" value="&lt;b&gt;交替&lt;/b&gt;：ShA[iter_k][xxxx]&amp;nbsp; =&amp;gt;&amp;nbsp; ShA[LocalSplitU * iter_k + pid_z][xxxx]" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="28" y="982" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-153" value="&lt;b&gt;注：&lt;/b&gt;使用到LocalSplitU参数，就需要增加shared memory（shape：block_size_m * block_size_n），用于累加多个Z维度block算出来的值" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="30" y="1048" width="740" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-161" value="&lt;div&gt;&lt;span&gt;&lt;b&gt;参数：&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-760" y="82" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-162" value="&lt;b&gt;LoopUnroll&lt;/b&gt;: 循环展开的次数" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="112" width="170" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-163" value="&lt;div&gt;&lt;b&gt;PrefetchLocalRead&lt;/b&gt;: 寄存器的预取&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="142" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-165" value="&lt;b&gt;PrefetchGlobalRead&lt;/b&gt;: shared的预取" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="172" width="210" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-166" value="&lt;b&gt;TransposeA/B&lt;/b&gt;: A/B矩阵是以转置输入，默认为行优先A转置B不转置" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="202" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-167" value="&lt;b&gt;transposeLDSA/B&lt;/b&gt;: shared memory A/B是否是转置存储，默认为行优先shA转置B不转置" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="232" width="490" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-168" value="&lt;b&gt;LocalSplitU&lt;/b&gt;: 在外积循环层使用增加blockz减少外积次数" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="260" width="310" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-169" value="&lt;b&gt;CrossLocalSplitU&lt;/b&gt;: 使用LocalSplitU参数时才会起作用，为true则是使用交叉的方式进行访存" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="292" width="500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-170" value="&lt;b&gt;GlobLoadWidthA/B&lt;/b&gt;:&amp;nbsp;从 glob A/B到 shared A/B 每个线程访存的宽度" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="322" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-172" value="&lt;b&gt;WarpScatterSizeA/B&lt;/b&gt;: 从shared A/B 到 regA/B 时，以block内部的warp进行分散取数的数据大小" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="352" width="520" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-173" value="&lt;b&gt;ThreadScatterSizeA/B&lt;/b&gt;: 从shared A/B 到 regA/B 时，以warp内部的thread进行分散取数的数据大小" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="382" width="540" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-175" value="&lt;b&gt;ThreadTile&lt;/b&gt;: 线程计算的分块大小" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="412" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-176" value="&lt;b&gt;BlockTile&lt;/b&gt;: block计算的分块大小，其中还包括一个K" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="440" width="290" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-177" value="&lt;b&gt;BlockMapping&lt;/b&gt;: 提高L2 cache命中率/重新映射block的序号与所计算的blocktile的关系(映射关系以确定/控制groupM大小)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
          <mxGeometry x="-750" y="470" width="650" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-179" value="&lt;b&gt;已知：&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
