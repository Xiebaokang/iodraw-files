        <mxCell id="WgSi36YBb3g61TZYZooB-787" value="&lt;b&gt;ty&lt;/b&gt; = &lt;b&gt;warpid / (BN/TN/WarpX) &lt;/b&gt;* WarpY&amp;nbsp; &amp;nbsp; // block层面（与水平相同）&lt;br&gt;&amp;nbsp; &amp;nbsp; + &lt;b&gt;groupid / 1&lt;/b&gt; * 2&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;// warp层面&lt;br&gt;&amp;nbsp; &amp;nbsp; + &lt;b&gt;glaneid / WarpX&lt;/b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // thread层面" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1166.25" y="673.88" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-788" value="&lt;b&gt;tx &lt;/b&gt;= &lt;b&gt;warpid % (BN/TN/WarpX)&lt;/b&gt; * WarpX&amp;nbsp; &amp;nbsp; // block层面（与水平相同）&lt;br&gt;&amp;nbsp; &amp;nbsp; + &lt;b&gt;groupid %&lt;/b&gt; &lt;b&gt;1&lt;/b&gt; * WarpX&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // warp层面&lt;br&gt;&amp;nbsp; &amp;nbsp; + &lt;b&gt;glaneid % WarpX&lt;/b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // thread层面" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1166.25" y="736.13" width="390" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-789" value="对于warp中线程的排布有：" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1685" y="40" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-792" value="在进行外积时，若 ThreadTile&amp;nbsp; 大于 SharedLoadVectorWidthA/B，则每个thread需要进分散load(shared-&amp;gt;reg)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="843" y="872" width="590" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-796" value="&lt;span style=&quot;&quot;&gt;分散的次数&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="853.75" y="943.25" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-797" value="分散的间距" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="853.75" y="1068.25" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-799" value="&lt;b&gt;timeM = TM / SharedLoadVectorWidthA&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="938.75" y="923.25" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-800" value="&lt;b&gt;timeN = TN / SharedLoadVectorWidthB&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="938.75" y="961.25" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-801" value="" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;strokeWidth=1;fontSize=12;align=left;" parent="1" vertex="1">
          <mxGeometry x="918.75" y="923.25" width="20" height="58" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-802" value="&lt;b&gt;intervalM = BM / timeM&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="939.75" y="1048.5" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-803" value="&lt;b&gt;intervalN = BN / timeN&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="939.75" y="1086.5" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-804" value="" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;strokeWidth=1;fontSize=12;align=left;" parent="1" vertex="1">
          <mxGeometry x="919.75" y="1048.5" width="20" height="58" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-805" value="VECTORLOAD(reg[&lt;b&gt;time * SharedLoadVectorWidth&lt;/b&gt;]) &lt;br&gt;= VECTORLOAD(sh[&lt;b&gt;iter_k&lt;/b&gt;][&lt;b&gt;time * interval + tx/y * SharedLoadVectorWidth&lt;/b&gt;]);" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1208" y="953.75" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-806" value="&lt;b&gt;①&lt;/b&gt; 若&lt;b&gt;无LocalSplitU&lt;/b&gt;且&lt;b&gt;transposeLDS&lt;/b&gt;与load&lt;b&gt;方向一致&lt;/b&gt;则：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1193" y="930" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-807" value="&lt;b&gt;②&lt;/b&gt; 若&lt;b&gt;有LocalSplitU&lt;/b&gt;且&lt;b&gt;transposeLDS&lt;/b&gt;与load&lt;b&gt;方向一致&lt;/b&gt;则（有交叉与等距两种）：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1193" y="1003.75" width="440" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-809" value="交叉：sh[&lt;b&gt;LocalSplitU * iter_k + pid_z&lt;/b&gt;][xxxx]" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1208" y="1025.5" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-810" value="等距：sh[&lt;b&gt;pid_z * (block_size_k / LocalSplitU) + iter_k&lt;/b&gt;][xxxx]" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1208" y="1045.5" width="350" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-811" value="&lt;b&gt;③&lt;/b&gt; 若&lt;b&gt;无LocalSplitU&lt;/b&gt;且&lt;b&gt;transposeLDS&lt;/b&gt;与load&lt;b&gt;方向不一致&lt;/b&gt;则：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1193" y="1084" width="330" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-812" value="for(int i=0; i&amp;lt;&lt;b&gt;SharedLoadVectorWidth&lt;/b&gt;; i++)&lt;br&gt;&amp;nbsp; &amp;nbsp; reg[&lt;b&gt;time * SharedLoadVectorWidth + i&lt;/b&gt;]&lt;br&gt;&amp;nbsp; &amp;nbsp; = sh[&lt;b&gt;time * interval + tx/y * SharedLoadVectorWidth + i&lt;/b&gt;][&lt;b&gt;iter_k&lt;/b&gt;]" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1208" y="1104" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-813" value="&lt;b&gt;注：iter_k为外积循环变量 、pid_z为blockidx.z&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1208" y="901.25" width="270" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-815" value="将regC写回Global分为两种情况：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="2500" y="62" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-816" value="2. 若使用了 LocalSplitU 参数，则需要将 regC 的结果累加到 sharedC 中，再由 sharedC 由经 temp reg 写回到 GlobC 中" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="2510" y="264" width="650" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-817" value="1. 若没有使用 LocalSplitU 参数，则直接将 regC 中的值写回到 GlobC 中，且使用 GlobalStoreVectorWidthC 进行 store 操作" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="2510" y="98.75" width="670" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-818" value="for (int i=0; i&amp;lt;timeM; i++) {&lt;br&gt;&amp;nbsp; &amp;nbsp; for (int j=0; j&amp;lt;timeN; j++) {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;for (int k=0; k&amp;lt;SharedLoadVecotr)&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; VL(C[][]) = VL(regC[][]);&lt;br&gt;&amp;nbsp; &amp;nbsp; }&lt;br&gt;}" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="2522" y="99" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-823" value="&lt;div style=&quot;&quot;&gt;&lt;span&gt;Glob&amp;nbsp; To Shread&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-794" y="1200" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-824" value="参数：GlobLoadWidthA/B&amp;nbsp; （每个线程在A/B上一次load的数据宽度）" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-780" y="1239" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-825" value="&lt;div style=&quot;text-align: left&quot;&gt;&lt;span&gt;BlockTile：(BM, BN, BK)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left&quot;&gt;&lt;span&gt;ThreadTile：(TM, TN)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left&quot;&gt;&lt;span&gt;ThreadNumPerBlock：BM / TM * BN / TN&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left&quot;&gt;&lt;span&gt;BlockTileASize：BM * BK&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-785" y="1275" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-826" value="LoadWidthPerThread：BlockTileASize / ThreadNumPerBlock" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-413" y="1295" width="340" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-827" value="" style="shape=flexArrow;endArrow=classic;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#fff2cc;fontSize=12;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="-490" y="1304.58" as="sourcePoint" />
            <mxPoint x="-450" y="1304.58" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-828" value="我们取数据是按照GlobLoadWidthA/B宽度取，但是每个线程需要取LoadWidthPerThread宽度的数据" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-780" y="1360" width="540" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-830" value="若LoadWidthPerThread为8，则GlobLoadWidthA/B可取值[1, 8]且由float1/2/4的最优组合进行表示" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-780" y="1395" width="530" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-832" value="若GlobLoadWidthA/B取6，则由float4+float2表示6，剩下的一部分宽度为2，则使用float2" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-780" y="1428" width="480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-833" value="若剩下的一部分仍然大于6，则再分出一个6的宽度数据块出来，直至将所有数据全部取完" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-780" y="1460" width="480" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-834" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=left;" parent="1" vertex="1">
          <mxGeometry x="-270" y="1430" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-835" value="loadwidth=6" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="-270" y="1430" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-837" value="&lt;span&gt;loadwidth=2&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=center;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="-270" y="1460" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-838" value="" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#fff2cc;fontSize=12;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="-10.689999999999998" y="1430" as="sourcePoint" />
            <mxPoint x="-11" y="1480" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-839" value="Shared To Registers" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-794" y="1540" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-840" value="参数：&lt;br&gt;&amp;nbsp; &amp;nbsp; WarpScatterSizeA/B（以block内部的warp进行分散取数的数据大小）&lt;br&gt;&amp;nbsp; &amp;nbsp; ThreadScatterSizeA/B（以warp内部的thread进行分散取数的数据大小）" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-769" y="1565" width="410" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-841" value="BlockSize (BM/TM, BN/TN)&lt;br&gt;WarpLayout (WarpY, WarpX)&lt;br&gt;BlockLayout (BM/TM/WarpY, BN/TN/WarpX)&amp;nbsp; &amp;nbsp; &amp;nbsp;// 以 warp 为单位的 block 的布局" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="-750" y="1640" width="440" height="50" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-843" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=left;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="86.32" y="1670" width="90" height="320" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-844" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=left;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="198.32" y="1570" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-845" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=left;" parent="1" vertex="1">
          <mxGeometry x="198.32" y="1670" width="240" height="320" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-846" value="&lt;font style=&quot;font-size: 25px&quot;&gt;64&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="46.32" y="1820" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-847" value="&lt;span style=&quot;font-size: 25px&quot;&gt;16&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="108.32" y="1650" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-848" value="&lt;span style=&quot;font-size: 25px&quot;&gt;16&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="158.32" y="1600" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-849" value="&lt;span style=&quot;font-size: 25px&quot;&gt;48&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="298.32" y="1550" width="40" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-850" value="&lt;div style=&quot;text-align: left&quot;&gt;&lt;span style=&quot;font-size: 25px&quot;&gt;blocktile (64, 48, 16)&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-size: 25px&quot;&gt;&lt;div style=&quot;text-align: left&quot;&gt;&lt;span&gt;threadtile (4, 6)&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="47" y="1335" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-853" value="&lt;span style=&quot;font-size: 25px&quot;&gt;blocksize (16, 8)&lt;br&gt;warplayout (8, 8)&lt;br&gt;&lt;/span&gt;&lt;div style=&quot;text-align: left&quot;&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="457.5" y="1335" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-854" value="" style="shape=flexArrow;endArrow=classic;html=1;strokeColor=#000000;strokeWidth=2;fillColor=#fff2cc;fontSize=12;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="340.5" y="1360" as="sourcePoint" />
            <mxPoint x="420.5" y="1360" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-857" value="&lt;font style=&quot;font-size: 18px&quot;&gt;warp0&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=center;" parent="1" vertex="1">
          <mxGeometry x="198.32" y="1670" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-858" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=12;align=left;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
