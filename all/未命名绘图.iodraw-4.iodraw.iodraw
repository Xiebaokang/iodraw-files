        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-785" value="&lt;b&gt;tx &lt;/b&gt;= &lt;b&gt;warpid % (BN/TN/WarpX)&lt;/b&gt; * WarpX&amp;nbsp; &amp;nbsp; // block层面&lt;br&gt;&amp;nbsp; &amp;nbsp; + &lt;b&gt;groupid %&lt;/b&gt; &lt;b&gt;(WarpX / 2)&lt;/b&gt; * 2&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // warp层面&lt;br&gt;&amp;nbsp; &amp;nbsp; + &lt;b&gt;glaneid % 2&lt;/b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;// thread层面" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1166.25" y="551.88" width="310" height="50" as="geometry" />
        </mxCell>
