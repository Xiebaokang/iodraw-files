        <mxCell id="WgSi36YBb3g61TZYZooB-183" value="&lt;b&gt;tid&lt;/b&gt; 为block中的线程序号" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
