        <mxCell id="WgSi36YBb3g61TZYZooB-112" value="pid为grid中block的序号，要求从pid映射到pid_m和pid_n" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" parent="1" vertex="1">
