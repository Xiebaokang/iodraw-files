        <mxCell id="WgSi36YBb3g61TZYZooB-676" value="当warp的shape确定了以后block的布局也随之确定：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="846.25" y="260" width="290" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-677" value="&lt;b&gt;BlockShape (BM/TM, BN/TN)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="853.75" y="195.12" width="180" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-679" value="LDS.128 (float4)&lt;br&gt;memory transaction 128byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1740" y="667.75" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-681" value="LDS.64 (float2)&lt;br&gt;memory transaction 128byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1940" y="667.75" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-682" value="LDS.32 (float)&lt;br&gt;memory transaction 128byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="2140" y="667.75" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-683" value="LDS.128 (float4)&lt;br&gt;memory transaction 128byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1740" y="923.25" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-684" value="LDS.64 (float2)&lt;br&gt;memory transaction 128byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1940" y="923.25" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-685" value="LDS.32 (float)&lt;br&gt;memory transaction 128byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="2140" y="923.25" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-687" value="warp以竖直方向进行ZOrder排布，也就是&lt;b&gt;thread i 与 i^1&lt;/b&gt; 访存操作一致" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1830" y="713.25" width="390" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-691" value="&lt;p style=&quot;margin: 1.4em 0px ; color: rgb(25 , 27 , 31) ; background-color: rgb(255 , 255 , 255)&quot;&gt;&lt;/p&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1985" y="342" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-692" value="使用 &lt;b&gt;LDS.64 指令&lt;/b&gt;（或者通过 float2、uint2 等类型）取数据时，每个 thread 请求 64 bit 数据，那么每 16 个 thread 就需要请求 128 bytes 的数据。&lt;br&gt;所以 warp 将被拆分成 4 部分，每部分产生一次 memory transaction。即一共 4 次 transaction。&lt;br&gt;&lt;br&gt;使用&lt;b&gt; LDS.128 指令&lt;/b&gt;（或者通过 float4、uint2 等类型）取数据时，每个 thread 请求 128bit 数据，那么每 8 个 thread 就需要请求 128 bytes 的数据。&lt;br&gt;所以 warp 将被拆分成 8 部分，每部分产生一次 memory transaction。即一共 8 次 transaction。&lt;br&gt;&lt;br&gt;&lt;span&gt;只有以下两个条件之一满足时，这 warp 的每两个部分的访问才会合并成一次 memory transaction：&lt;br&gt;&lt;/span&gt;&amp;nbsp; &amp;nbsp; 1. 对于 Warp 内所有活跃的&lt;b&gt;第 i 号线程，第 i xor 1 号&lt;/b&gt;线程不活跃或者访存地址和其一致（T0==T1, T2==T3, T4==T5, T6==T7...）&lt;br&gt;&amp;nbsp; &amp;nbsp; 2. 对于 Warp 内所有活跃的&lt;b&gt;第 i 号线程，第 i xor 2 号&lt;/b&gt;线程不活跃或者访存地址和其一致（T0==T2, T1==T3, T4==T6, T5==T7...）&lt;br&gt;&lt;br&gt;&lt;b&gt;注：LDS.128指令时，只有连续的两个部分才能进行事务的合并&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1675.5" y="292" width="785" height="178" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-697" value="warp以水平方向进行ZOrder排布，也就是&lt;b&gt;thread i 与 i^2 &lt;/b&gt;访存操作一致" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1830" y="969.25" width="390" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-698" value="图1中0-7/8-15号thread即可执行一个128byte的事务，0-7和8-15号的thread访问两部分相同的元素且&lt;b&gt;为连续的warp的两部分&lt;/b&gt;，可合并成一个128byte事务" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1658" y="1018.75" width="820" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-699" value="图2中0-15号线程执行一个128byte的事务，16-31号thread也执行一个128byte的事务，两部分访问的数据在一个事务中，则可合并成一个128byte事务" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1658" y="1048.75" width="800" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-700" value="图3中0-31号线程执行一个128byte的事务，32-63号线程执行一个128byte的事务" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1658" y="1077.25" width="440" height="20" as="geometry" />
        </mxCell>
        <mxCell id="WgSi36YBb3g61TZYZooB-701" value="现在只需要确定warp中线程的映射方式即可，也就是如下图所示：" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1120" y="142" width="370" height="20" as="geometry" />
        </mxCell>
