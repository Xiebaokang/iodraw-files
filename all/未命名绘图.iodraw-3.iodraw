        <mxCell id="vwsM5nAZA5b_mvNWWmDU-257" value="&lt;b&gt;smP&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
