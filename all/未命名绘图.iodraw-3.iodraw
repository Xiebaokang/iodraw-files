        <mxCell id="vwsM5nAZA5b_mvNWWmDU-624" value="&lt;div&gt;m &lt;b&gt;=&lt;/b&gt; max(rowMax, smRowMax)&lt;/div&gt;&lt;div&gt;smRowSum &lt;b&gt;=&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;exp(x0 - smRowMax) + exp(x1-smRowMax) + ...&amp;nbsp; + exp(xi - smRowMax)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;rowSum &lt;b&gt;=&lt;/b&gt; exp(xi+1 - rowMax) + exp(xi+2 - rowMax) + ... + exp(xi+j - rowMax)&lt;/div&gt;d &lt;b&gt;= &lt;/b&gt;smRowSum&amp;nbsp;* exp(smMax - m) + rowSum * exp(rowMax - m)&lt;div&gt;&amp;nbsp; &amp;nbsp;&lt;b&gt;=&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;exp(x0 - m) + exp(x1-m) + ...&amp;nbsp; + exp(xi - m) +&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;exp(xi+1 - m) + exp(xi+2 - m) + ... + exp(xi+j - m)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;smRowSum &lt;b&gt;=&lt;/b&gt; d&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;smRowMax &lt;b&gt;= &lt;/b&gt;m&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;smFactor &lt;b&gt;=&lt;/b&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;exp(smMax - m)&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;labelBorderColor=#ff0000;" vertex="1" parent="1">
