ize=1;" vertex="1" parent="1"><mxGeometry x="1995" y="846.25" width="30" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-346" value="" style="html=1;shadow=0;dashed=0;align=center;verticalAlign=middle;shape=mxgraph.arrows2.arrow;dy=0.57;dx=19.82;notch=0;fillColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="1490" y="816.25" width="40" height="70" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-347" value="" style="html=1;shadow=0;dashed=0;align=center;verticalAlign=middle;shape=mxgraph.arrows2.arrow;dy=0.57;dx=19.82;notch=0;fillColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="1830" y="816.25" width="40" height="70" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-349" value="&lt;b&gt;load：&lt;/b&gt;由warp中线程确定好起始地址后，warp运行ldmatrix指令会从提供的每个起始地址开始向后取8*f16（128bit）数据存储到每个线程的registers中；" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1270" y="651.25" width="820" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-352" value="&lt;b&gt;注2：&lt;/b&gt;如果n=1，则32个thread load一个8*8=64个elem，则每个thread load 2个elem(f16)=1个elem(f32/int)，也就是32bit，且R寄存器的宽度为32bit，则n=1，R个数为1，以此类推" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1270" y="691.25" width="960" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-353" value="&lt;b&gt;注3：&lt;/b&gt;如果n=4，当load完成后，再将数据重新分配（自己的说法）到每个线程的registers，例如：T0 register存储由T0、T8、T16、T24确定的地址的前32bit的数据" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1270" y="711.25" width="880" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-354" value="&lt;font style=&quot;font-size: 9px&quot;&gt;T7&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1580" y="836.25" width="30" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-355" value="&lt;font style=&quot;font-size: 18px&quot;&gt;Grid Level&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="395" y="540" width="100" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-358" value="&lt;font style=&quot;font-size: 18px&quot;&gt;Block Level&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="935" y="540" width="110" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-359" value="&lt;font style=&quot;font-size: 18px&quot;&gt;Warp Level&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1395" y="540" width="110" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-362" value="&lt;font style=&quot;font-size: 18px&quot;&gt;MMA Level&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1990" y="540" width="100" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-363" value="&lt;font style=&quot;font-size: 18px&quot;&gt;①Store&lt;/font&gt;" style="html=1;shadow=0;dashed=0;align=center;verticalAlign=middle;shape=mxgraph.arrows2.arrow;dy=0.6;dx=40;notch=0;fillColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="640" y="405" width="160" height="70" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-364" value="&lt;span style=&quot;font-size: 18px&quot;&gt;②Load&lt;/span&gt;" style="html=1;shadow=0;dashed=0;align=center;verticalAlign=middle;shape=mxgraph.arrows2.arrow;dy=0.6;dx=40;notch=0;fillColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="1574" y="405" width="160" height="70" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-365" value="&lt;font style=&quot;font-size: 18px&quot;&gt;①从global store shared的过程&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="445" y="997" width="260" height="20" as="geometry"/></mxCell><mxCell id="k33l_gbeuz6RrAbma-9G-366" value="&lt;font style=&quot;font-size: 18px&quot;&gt;②从shared load registers的过程&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1"><mxGeometry x="1570" y="997" width="270" height="20" as="geometry"/></mxCell></root></mxGraphModel>